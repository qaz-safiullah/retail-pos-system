@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card text-white bg-primary shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Total Products</h5>
                    <h3 class="card-text">@ViewBag.TotalProducts</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-success shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Total Orders</h5>
                    <h3 class="card-text">@ViewBag.TotalOrders</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-dark shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Total Sales</h5>
                    <h3 class="card-text">Rs @ViewBag.TotalSales</h3>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mt-5 mb-3">Low Stock Products</h4>

    <div class="table-responsive">
        <table class="table table-bordered table-striped text-center">
            <thead class="table-dark">
                <tr>
                    <th>Product</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.LowStockProducts)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.StockQuantity</td>
                        <td>
                            <button class="btn btn-sm btn-success" onclick="openRestockModal(@item.ProductId)">Restock</button>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>
@Html.AntiForgeryToken()

<!-- Modal -->
<div class="modal fade" id="restockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Restock Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="number" id="restockQuantity" class="form-control" placeholder="Enter quantity" min="1" />
                <input type="hidden" id="restockProductId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmRestock">Restock</button>
            </div>
        </div>
    </div>
</div>

<script>
    function openRestockModal(productId) {
        document.getElementById('restockProductId').value = productId;
        document.getElementById('restockQuantity').value = '';
        var modal = new bootstrap.Modal(document.getElementById('restockModal'));
        modal.show();
    }

    document.getElementById('confirmRestock').addEventListener('click', function () {
        var productId = parseInt(document.getElementById('restockProductId').value);
        var quantityToAdd = parseInt(document.getElementById('restockQuantity').value);

        if (isNaN(quantityToAdd) || quantityToAdd <= 0) {
            alert('Please enter a valid quantity');
            return;
        }

        fetch('@Url.Action("RestockProduct", "Admin")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            body: JSON.stringify({ productId: productId, quantityToAdd: quantityToAdd })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert('Stock updated! New stock: ' + data.newStock);
                location.reload(); // reload dashboard to update table
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(err => {
            console.error(err);
            alert('Something went wrong while restocking.');
        });
    });
</script>

