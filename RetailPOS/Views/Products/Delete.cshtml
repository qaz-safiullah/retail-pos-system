@model RetailPOS.Models.ProductViewModel

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <h3 class="card-title text-center mb-3 text-danger">Delete Product</h3>

                    <p class="text-center">Are you sure you want to delete this product?</p>

                    <dl class="row">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Category</dt>
                        <dd class="col-sm-8">@ViewBag.CategoryName</dd>
                    </dl>

                    <form asp-action="Delete" method="post" class="d-flex justify-content-between">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ProductId" />
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
