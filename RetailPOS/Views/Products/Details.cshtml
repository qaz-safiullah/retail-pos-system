@model RetailPOS.Models.ProductViewModel

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="card-title mb-3 text-center">Product Details</h3>
                    <hr />

                    <dl class="row">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Barcode</dt>
                        <dd class="col-sm-8">@Model.Barcode</dd>

                        <dt class="col-sm-4">Price</dt>
                        <dd class="col-sm-8">@Model.Price.ToString("0.00")</dd>

                        <dt class="col-sm-4">Stock Quantity</dt>
                        <dd class="col-sm-8">@Model.StockQuantity</dd>

                        <dt class="col-sm-4">Category</dt>
                        <dd class="col-sm-8">@ViewBag.CategoryName</dd>

                        <dt class="col-sm-4">Is Active</dt>
                        <dd class="col-sm-8">@(Model.IsActive ? "Yes" : "No")</dd>
                    </dl>

                    <div class="d-flex justify-content-center mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
