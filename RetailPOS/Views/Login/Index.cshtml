@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - RetailPOS</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .login-card {
            border-radius: 0.5rem;
        }

            .login-card .card-body {
                padding: 2rem;
            }

        .login-title {
            font-weight: 600;
            font-size: 1.5rem;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="row justify-content-center align-items-center" style="height:100vh;">
            <div class="col-md-4">
                <div class="card shadow login-card">
                    <div class="card-body">
                        <h4 class="text-center login-title mb-4">RetailPOS Login</h4>

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label">Username</label>
                                <input name="username" class="form-control" placeholder="Enter your username" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" name="password"
                                       class="form-control" placeholder="Enter your password" required />
                            </div>

                            <button class="btn btn-primary w-100 mt-3">Login</button>
                        </form>
                    </div>
                </div>
                <p class="text-center text-muted mt-2">© 2025 RetailPOS</p>
            </div>
        </div>
    </div>

</body>
</html>
