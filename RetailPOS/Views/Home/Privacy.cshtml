@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">@ViewData["Title"]</h2>

    <div class="card shadow-sm p-4">
        <p>Your privacy is important to us at <strong>RetailPOS</strong>. This Privacy Policy explains how we collect, use, and protect your personal information when you use our application.</p>

        <h5 class="mt-3">1. Information We Collect</h5>
        <ul>
            <li>Personal details like name, email, and contact information.</li>
            <li>Usage data to improve our services.</li>
            <li>Transaction data such as purchases and payment information.</li>
        </ul>

        <h5 class="mt-3">2. How We Use Your Information</h5>
        <ul>
            <li>To provide and improve our services.</li>
            <li>To process transactions securely.</li>
            <li>To communicate important updates and information.</li>
        </ul>

        <h5 class="mt-3">3. Data Protection</h5>
        <p>We implement appropriate technical and organizational measures to protect your personal data against unauthorized access, alteration, or disclosure.</p>

        <h5 class="mt-3">4. Sharing Your Information</h5>
        <p>We do not sell or share your personal information with third parties except as required by law or to provide services on your behalf (e.g., payment processing).</p>

        <h5 class="mt-3">5. Your Rights</h5>
        <p>You have the right to access, correct, or delete your personal information. Contact our support team for any privacy-related requests.</p>

        <p class="mt-3"><em>By using RetailPOS, you agree to the terms outlined in this Privacy Policy.</em></p>

        <div class="mt-4">
            @if (Context.Session.GetString("Role")==("Admin"))
            {
                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-primary">Back to Dashboard</a>
            }
            else if (Context.Session.GetString("Role")==("Cashier"))
            {
                <a asp-controller="Cashier" asp-action="Dashboard" class="btn btn-primary">Back to Dashboard</a>
            }
            else
            {
                <a asp-controller="Login" asp-action="Index" class="btn btn-primary">Back</a>
            }
        </div>

    </div>
</div>
