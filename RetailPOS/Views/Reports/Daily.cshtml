@model dynamic

<h2>Daily Sales Report</h2>

@if (Model == null)
{
    <div class="alert alert-info">No sales today.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
        <tr>
            <th>Date</th>
            <th>Total Orders</th>
            <th>Total Revenue</th>
        </tr>
        </thead>
        <tr>
            <td>@Model.Date.ToShortDateString()</td>
            <td>@Model.TotalOrders</td>
            <td>Rs @Model.TotalRevenue</td>
        </tr>
    </table>
}

<a asp-action="Index" class="btn btn-secondary">Back</a>
